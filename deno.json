{
  "name": "@eabrouwer3/dacha",
  "version": "0.4.0",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@cliffy/command": "jsr:@cliffy/command@^1",
    "fast-check": "npm:fast-check@^3"
  },
  "tasks": {
    "dev": "deno run --watch --allow-all src/cli.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "setup-hooks": "git config core.hooksPath .githooks",
    "install": "deno install --allow-all --global --name dacha src/cli.ts"
  },
  "compilerOptions": {
    "strict": true
  }
}
