{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@cliffy/command": "jsr:@cliffy/command@^1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1",
    "fast-check": "npm:fast-check@^3"
  },
  "tasks": {
    "dev": "deno run --watch --allow-all src/cli.ts",
    "test": "deno test --allow-all",
    "compile": "deno compile --allow-all --output dacha src/cli.ts",
    "compile:darwin-arm64": "deno compile --allow-all --target aarch64-apple-darwin --output dacha-darwin-arm64 src/cli.ts",
    "compile:darwin-x64": "deno compile --allow-all --target x86_64-apple-darwin --output dacha-darwin-x64 src/cli.ts",
    "compile:linux-arm64": "deno compile --allow-all --target aarch64-unknown-linux-gnu --output dacha-linux-arm64 src/cli.ts",
    "compile:linux-x64": "deno compile --allow-all --target x86_64-unknown-linux-gnu --output dacha-linux-x64 src/cli.ts"
  },
  "compilerOptions": {
    "strict": true
  }
}
